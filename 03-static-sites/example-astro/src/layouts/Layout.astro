---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'vps-lab — VPS self-hosted do zero com Coolify, Docker e Ubuntu',
  description = 'Série pública em 7 episódios: do hardening ao deploy automatizado. Documentação honesta de quem fez, quebrou e corrigiu. Scripts prontos, perrengues reais e lições práticas.'
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/identity/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/identity/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/identity/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/identity/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/identity/favicon/site.webmanifest" />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://vpslab.com.br" />
    <meta property="og:image" content="https://vpslab.com.br/identity/og/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="vps-lab" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://vpslab.com.br/identity/og/og-image.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- Umami Analytics (EP08) -->
    <script defer src="https://umami.vpslab.com.br/script.js" data-website-id="7a671f72-379d-4698-9ba7-246cc68411ee" data-do-not-track="true"></script>

    <style is:global>
      :root {
        --bg:        #0C0C1A;
        --surface:   #13131f;
        --surface-dim: #0f0f1c;
        --border:    #1e2130;
        --border-dim: #1a1d2a;
        --accent:    #3b82f6;
        --accent-dim: rgba(59, 130, 246, 0.12);
        --text:      #f1f5f9;
        --muted:     #64748b;
        --muted-dim: #2d3748;
        --mono:      'JetBrains Mono', 'Fira Code', monospace;
        --sans:      'DM Sans', system-ui, sans-serif;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
      }

      /* grid de pontos no fundo */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
      }

      /* fade lateral para suavizar o grid */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 50% at 50% 0%, rgba(59,130,246,0.04) 0%, transparent 70%),
          radial-gradient(ellipse 80% 40% at 50% 100%, rgba(12,12,26,0.8) 0%, transparent 60%);
        pointer-events: none;
        z-index: 0;
      }

      main { position: relative; z-index: 1; }

      a { color: inherit; text-decoration: none; }

      ::selection {
        background: var(--accent);
        color: #fff;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
