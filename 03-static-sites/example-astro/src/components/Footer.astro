<footer>
  <div class="inner">
    <div class="left">
      <span class="name">vps-lab · vpslab.com.br</span>
      <span class="bork">
        VPS na <a href="https://cliente.borkcloud.com.br/aff.php?aff=7" target="_blank" rel="noopener">Bork Cloud</a>
      </span>
    </div>
    <div class="right">
      <a href="https://github.com/felipebossolani/vps-lab" target="_blank" rel="noopener">github</a>
      <a href="https://linkedin.com/in/felipebossolani" target="_blank" rel="noopener">linkedin</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 6rem;
    padding: 2.5rem 0;
    position: relative;
    z-index: 1;
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .name {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted-dim);
  }

  .bork {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted-dim);
  }

  .bork a {
    color: var(--accent);
    transition: opacity 0.15s;
  }

  .bork a:hover { opacity: 0.7; }

  .right {
    display: flex;
    gap: 1.5rem;
  }

  .right a {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted-dim);
    transition: color 0.15s;
  }

  .right a:hover { color: var(--muted); }

  @media (max-width: 600px) {
    .inner {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>
