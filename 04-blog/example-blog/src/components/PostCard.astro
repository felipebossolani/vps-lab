---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
}

const { title, description, date, slug, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/posts/${slug}`} class="card">
  <time datetime={date.toISOString()}>{formattedDate}</time>
  <h2>{title}</h2>
  <p>{description}</p>
  <div class="tags">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, transform 0.2s;
  }

  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  time {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  h2 {
    font-size: 1rem;
    color: var(--color-accent);
    margin: 0.4rem 0;
  }

  p {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.8rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.65rem;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.1rem 0.5rem;
  }
</style>
