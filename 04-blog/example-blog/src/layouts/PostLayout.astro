---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
const date = new Date(frontmatter.date).toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${frontmatter.title} — vps-lab blog`} description={frontmatter.description}>
  <main>
    <nav>
      <a href="/">&larr; voltar</a>
    </nav>

    <article>
      <header>
        <time datetime={frontmatter.date}>{date}</time>
        <h1>{frontmatter.title}</h1>
        <p class="description">{frontmatter.description}</p>
        <div class="tags">
          {frontmatter.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </header>

      <div class="content">
        <slot />
      </div>
    </article>

    <footer>
      <p>
        por <a href="https://linkedin.com/in/felipebossolani">Felipe Bossolani</a>
        · <a href="https://github.com/felipebossolani/vps-lab">GitHub</a>
      </p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem;
  }

  nav {
    padding: 1rem 0;
  }

  nav a {
    text-decoration: none;
    font-size: 0.85rem;
  }

  article header {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  time {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  h1 {
    font-size: 1.8rem;
    color: var(--color-accent);
    margin: 0.5rem 0;
    line-height: 1.3;
  }

  .description {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
  }

  .content {
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.2rem;
    color: var(--color-accent);
    margin: 2rem 0 1rem;
  }

  .content :global(h3) {
    font-size: 1rem;
    color: var(--color-text);
    margin: 1.5rem 0 0.5rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(code) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
    font-size: 0.85em;
  }

  .content :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .content :global(pre code) {
    border: none;
    padding: 0;
    background: none;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 0 0 1rem 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.3rem;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-muted);
    margin: 1rem 0;
  }

  footer {
    text-align: center;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    color: #666;
  }

  footer a {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
